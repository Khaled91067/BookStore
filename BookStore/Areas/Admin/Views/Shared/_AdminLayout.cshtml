1<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --admin-bg: #0f172a;
            --admin-surface: #1e293b;
            --admin-primary: #3b82f6;
            --admin-text: #f8fafc;
            --admin-text-muted: #94a3b8;
            --admin-border: #334155;
            --sidebar-width: 260px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--admin-bg);
            color: var(--admin-text);
            margin: 0;
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
        }

        /* Sidebar Styles */
        .admin-sidebar {
            width: var(--sidebar-width);
            background-color: var(--admin-surface);
            border-right: 1px solid var(--admin-border);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            transition: transform 0.3s ease;
        }

        .sidebar-brand {
            padding: 1.5rem;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--admin-text);
            text-decoration: none;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--admin-border);
        }

        .sidebar-brand i {
            color: var(--admin-primary);
        }

        .sidebar-nav {
            padding: 1rem 0;
            list-style: none;
            margin: 0;
        }

        .sidebar-nav-item {
            padding: 0.25rem 1rem;
        }

        .sidebar-nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            color: var(--admin-text-muted);
            text-decoration: none;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .sidebar-nav-link:hover, .sidebar-nav-link.active {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--admin-primary);
        }

        .sidebar-nav-link i {
            margin-right: 0.75rem;
            font-size: 1.2rem;
        }

        /* Main Content */
        .admin-main {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .admin-topbar {
            height: 70px;
            background-color: var(--admin-surface);
            border-bottom: 1px solid var(--admin-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            z-index: 999;
        }

        .topbar-btn {
            background: none;
            border: none;
            color: var(--admin-text-muted);
            font-size: 1.2rem;
            cursor: pointer;
            transition: color 0.2s;
        }
        
        .topbar-btn:hover {
            color: var(--admin-text);
        }

        /* Content Area */
        .admin-content {
            padding: 2rem;
            margin-top: 70px; /* Offset for fixed topbar */
            flex-grow: 1;
        }

        @@media (max-width: 991px) {
            :root {
                --sidebar-width: 70px;
            }
            .admin-sidebar {
                transform: none !important;
            }
            .sidebar-brand {
                justify-content: center;
                padding: 1.25rem 0;
            }
            .brand-text {
                display: none !important;
            }
            .sidebar-nav-item {
                padding: 0.25rem 0.5rem;
            }
            .sidebar-nav-link {
                justify-content: center;
                padding: 0.75rem 0;
            }
            .sidebar-nav-link i {
                margin-right: 0 !important;
                font-size: 1.4rem;
            }
            .sidebar-nav-link span {
                display: none !important;
            }
            .sidebar-section-header {
                display: none !important;
            }
            .admin-main {
                margin-left: var(--sidebar-width) !important;
            }
            .admin-topbar {
                left: var(--sidebar-width) !important;
            }
        }

        /* Premium Dark Theme Overrides for standard Bootstrap elements */
        .card {
            background-color: var(--admin-surface) !important;
            border: 1px solid var(--admin-border) !important;
            color: var(--admin-text) !important;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        }
        .card-header {
            background-color: rgba(15, 23, 42, 0.3) !important;
            border-bottom: 1px solid var(--admin-border) !important;
            color: var(--admin-text) !important;
        }
        .card-header .bg-dark {
            background-color: transparent !important;
        }
        .card-body {
            color: var(--admin-text) !important;
        }
        .table {
            color: var(--admin-text) !important;
        }
        .table > :not(caption) > * > * {
            background-color: transparent !important;
            color: var(--admin-text) !important;
            border-bottom-color: var(--admin-border) !important;
        }
        .table .table-light, .table thead, .table tr[class*="table-light"] {
            background-color: rgba(15, 23, 42, 0.5) !important;
        }
        .table thead th, .table thead td {
            color: var(--admin-text-muted) !important;
            background-color: rgba(15, 23, 42, 0.5) !important;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            border-bottom: 1.5px solid var(--admin-border) !important;
        }
        .table-hover tbody tr:hover > * {
            background-color: rgba(255, 255, 255, 0.03) !important;
            color: var(--admin-text) !important;
        }
        .form-control, .form-select {
            background-color: var(--admin-bg) !important;
            border: 1px solid var(--admin-border) !important;
            color: var(--admin-text) !important;
        }
        .form-control:focus, .form-select:focus {
            background-color: var(--admin-bg) !important;
            border-color: var(--admin-primary) !important;
            color: var(--admin-text) !important;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25) !important;
        }
        .form-control::placeholder {
            color: var(--admin-text-muted) !important;
        }
        hr {
            color: var(--admin-border) !important;
            opacity: 0.3;
        }
        .text-muted {
            color: var(--admin-text-muted) !important;
        }
        .vr {
            background-color: var(--admin-border) !important;
            opacity: 0.5;
        }
        .btn-outline-danger {
            border-color: #ef4444 !important;
            color: #ef4444 !important;
        }
        .btn-outline-danger:hover {
            background-color: #ef4444 !important;
            color: white !important;
        }
        .btn-outline-success {
            border-color: #10b981 !important;
            color: #10b981 !important;
        }
        .btn-outline-success:hover {
            background-color: #10b981 !important;
            color: white !important;
        }
        .btn-outline-warning {
            border-color: #f59e0b !important;
            color: #f59e0b !important;
        }
        .btn-outline-warning:hover {
            background-color: #f59e0b !important;
            color: white !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="sidebar-brand">
            <i class="bi bi-book-half"></i><span class="brand-text ms-2">BookStore</span>
        </a>
        <ul class="sidebar-nav">
            <li class="sidebar-nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="sidebar-nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                </a>
            </li>
            <li class="sidebar-nav-item mt-4 mb-2 px-3">
                <span class="text-uppercase small fw-bold text-muted sidebar-section-header" style="letter-spacing: 1px;">Management</span>
            </li>
            <li class="sidebar-nav-item">
                <a asp-controller="Book" asp-action="Index" asp-area="Admin" class="sidebar-nav-link">
                    <i class="bi bi-book"></i><span>Books</span>
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a asp-controller="Category" asp-action="Index" class="sidebar-nav-link">
                    <i class="bi bi-tags"></i><span>Categories</span>
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a asp-controller="Author" asp-action="Index" class="sidebar-nav-link">
                    <i class="bi bi-people"></i><span>Authors</span>
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a asp-controller="User" asp-action="Index" class="sidebar-nav-link">
                    <i class="bi bi-shield-lock"></i><span>Users</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Wrapper -->
    <div class="admin-main">
        
        <!-- Topbar -->
        <header class="admin-topbar">
            <div>
                <!-- Mobile Toggle button could go here -->
                <h5 class="mb-0 fw-bold d-none d-md-block">Admin Panel</h5>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a asp-area="" asp-controller="UserBook" asp-action="Index" class="btn btn-sm btn-outline-light rounded-pill px-3">
                    <i class="bi bi-eye me-1"></i> Preview Store
                </a>
                <div class="dropdown">
                    <button class="d-flex align-items-center gap-2 bg-transparent border-0 text-white" type="button" data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=3b82f6&color=fff" alt="Admin" class="rounded-circle" width="32" height="32">
                        <span class="fw-medium d-none d-md-inline">@User.Identity?.Name</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark shadow">
                        <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                                <button type="submit" class="dropdown-item text-danger">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- AJAX Single-Page Navigation for Admin Panel -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Intercept clicks on links
            document.body.addEventListener("click", function (e) {
                const link = e.target.closest("a");
                if (!link) return;

                const href = link.getAttribute("href");
                if (!href) return;

                // Check if it's an admin link and not external/identity/logout/preview
                const isAbsolute = href.startsWith("http://") || href.startsWith("https://");
                const currentOrigin = window.location.origin;
                
                if (isAbsolute && !href.startsWith(currentOrigin)) return;

                let path = href;
                if (isAbsolute) {
                    path = href.substring(currentOrigin.length);
                }

                // Verify it's in the admin area, and not leaving to customer views or identity
                if (!path.toLowerCase().startsWith("/admin")) return;
                if (path.toLowerCase().includes("/account/") || path.toLowerCase().includes("/identity/")) return;
                if (link.hasAttribute("data-no-ajax")) return;

                e.preventDefault();
                loadAdminPage(path);
            });

            // Intercept form submissions
            document.body.addEventListener("submit", function (e) {
                const form = e.target.closest("form");
                if (!form) return;

                const action = form.getAttribute("action") || window.location.pathname;
                const method = (form.getAttribute("method") || "GET").toUpperCase();

                const isAbsolute = action.startsWith("http://") || action.startsWith("https://");
                const currentOrigin = window.location.origin;

                if (isAbsolute && !action.startsWith(currentOrigin)) return;

                let path = action;
                if (isAbsolute) {
                    path = action.substring(currentOrigin.length);
                }

                if (!path.toLowerCase().startsWith("/admin")) return;
                if (form.hasAttribute("data-no-ajax")) return;

                e.preventDefault();

                if (method === "GET") {
                    const params = new URLSearchParams(new FormData(form)).toString();
                    const url = path.split("?")[0] + "?" + params;
                    loadAdminPage(url);
                } else {
                    submitAdminForm(path, form);
                }
            });

            // Handle back/forward browser buttons
            window.addEventListener("popstate", function (e) {
                loadAdminPage(window.location.pathname + window.location.search, false);
            });

            function loadAdminPage(url, pushState = true) {
                const mainContent = document.querySelector(".admin-content");
                if (!mainContent) return;

                mainContent.style.opacity = "0.4";
                mainContent.style.transition = "opacity 0.15s ease";

                fetch(url)
                    .then(response => {
                        if (!response.ok) throw new Error("Network response was not ok");
                        return response.text();
                    })
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, "text/html");

                        // Update Page Title
                        document.title = doc.title;

                        // Update active sidebar state
                        updateActiveSidebar(url);

                        const newContent = doc.querySelector(".admin-content");
                        if (newContent) {
                            mainContent.innerHTML = newContent.innerHTML;
                            mainContent.style.opacity = "1";

                            // Execute newly loaded scripts
                            const scripts = doc.querySelectorAll(".admin-content script, body > script");
                            scripts.forEach(oldScript => {
                                const src = oldScript.getAttribute("src");
                                if (src && (src.includes("jquery") || src.includes("bootstrap"))) return;

                                const newScript = document.createElement("script");
                                Array.from(oldScript.attributes).forEach(attr => {
                                    newScript.setAttribute(attr.name, attr.value);
                                });
                                newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                                
                                document.body.appendChild(newScript);
                                newScript.parentNode.removeChild(newScript);
                            });
                        } else {
                            window.location.href = url;
                        }

                        if (pushState) {
                            window.history.pushState(null, doc.title, url);
                        }
                    })
                    .catch(error => {
                        console.error("AJAX navigation error:", error);
                        window.location.href = url;
                    });
            }

            function submitAdminForm(url, form) {
                const mainContent = document.querySelector(".admin-content");
                if (!mainContent) return;

                mainContent.style.opacity = "0.4";
                mainContent.style.transition = "opacity 0.15s ease";

                fetch(url, {
                    method: "POST",
                    body: new FormData(form)
                })
                .then(response => {
                    if (response.redirected) {
                        loadAdminPage(response.url);
                        return null;
                    }
                    if (!response.ok) throw new Error("Form post failed");
                    return response.text();
                })
                .then(html => {
                    if (html === null) return;

                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, "text/html");

                    document.title = doc.title;
                    updateActiveSidebar(url);

                    const newContent = doc.querySelector(".admin-content");
                    if (newContent) {
                        mainContent.innerHTML = newContent.innerHTML;
                        mainContent.style.opacity = "1";

                        const scripts = doc.querySelectorAll(".admin-content script, body > script");
                        scripts.forEach(oldScript => {
                            const src = oldScript.getAttribute("src");
                            if (src && (src.includes("jquery") || src.includes("bootstrap"))) return;

                            const newScript = document.createElement("script");
                            Array.from(oldScript.attributes).forEach(attr => {
                                newScript.setAttribute(attr.name, attr.value);
                            });
                            newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                            
                            document.body.appendChild(newScript);
                            newScript.parentNode.removeChild(newScript);
                        });
                    } else {
                        window.location.href = url;
                    }
                })
                .catch(error => {
                    console.error("AJAX form error:", error);
                    form.submit();
                });
            }

            function updateActiveSidebar(url) {
                const links = document.querySelectorAll(".admin-sidebar .sidebar-nav-link");
                links.forEach(link => {
                    link.classList.remove("active");
                    const href = link.getAttribute("href");
                    if (href) {
                        const urlLower = url.toLowerCase().split('?')[0];
                        const hrefLower = href.toLowerCase().split('?')[0];
                        
                        // Active check logic: exact match or sub-controller routes (e.g. /Admin/Book/AddEdit is matching /Admin/Book)
                        if (urlLower === hrefLower || (hrefLower !== "/admin" && urlLower.startsWith(hrefLower))) {
                            link.classList.add("active");
                        }
                    }
                });
            }
        });
    </script>
</body>
</html>
