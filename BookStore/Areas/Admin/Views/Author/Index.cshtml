@model IEnumerable<Author>
@{
    ViewData["Title"] = "Manage Authors";
}

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Manage Authors</h5>
        </div>
        <div class="card-body">

            <form asp-controller="Author" asp-action="Add" method="post" asp-area="Admin" enctype="multipart/form-data" class="row g-3 align-items-center mb-4">
                <div class="col-12 col-md-auto">
                    <label for="authorName" class="form-label fw-semibold mb-md-0">New Author:</label>
                </div>
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <input type="text" name="authorName" class="form-control" id="authorName" placeholder="e.g., Jane Doe" required />
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary">Add Author</button>
                </div>
            </form>

            <hr />

            <h6 class="text-muted mb-3">Existing Authors</h6>
            @if (Model == null || !Model.Any())
            {
                <p class="text-muted small">No authors created yet.</p>
            }
            else
            {
                <div class="table-responsive" style="max-width: 600px;">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-3" style="width: 80px;">Image</th>
                                <th scope="col">Author Name</th>
                                <th scope="col" class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var author in Model)
                            {
                                <tr>
                                    <td class="ps-3">
                                        @if (!string.IsNullOrEmpty(author.ImageUrl))
                                        {
                                            var authorImgUrl = author.ImageUrl.Contains("/") ? author.ImageUrl : $"/images/authors/{author.ImageUrl}";
                                            <img src="@authorImgUrl" alt="@author.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="bg-secondary rounded shadow-sm d-flex align-items-center justify-content-center text-white" style="width: 50px; height: 50px;">
                                                <i class="bi bi-person"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-semibold align-middle">@author.Name</td>
                                    <td class="text-end pe-3 align-middle">
                                        <form method="post" asp-controller="Author" asp-action="Delete" asp-route-id="@author.AuthorId" class="m-0" onsubmit="return confirm('Are you sure you want to delete this author?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
