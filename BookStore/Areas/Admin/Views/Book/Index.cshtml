@using BookStore.ViewModels
@model BooksPageVM
@{
    ViewData["Title"] = "Manage Books";
}

<div class="container my-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-3 px-3">
            <h5 class="fw-bold mb-0 text-white"><i class="bi bi-book-half me-2 text-primary"></i>Manage Books</h5>
            <a asp-action="AddEdit" asp-area="Admin" asp-controller="Book" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Add New Book
            </a>
        </div>
        <div class="card-body">
            
            <!-- Search Form -->
            <form method="get" asp-action="Index" class="row g-3 mb-4">
                <div class="col-12 col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent text-muted border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" value="@Model.SearchTerm" class="form-control border-start-0" placeholder="Search by title, author, category or publisher..." />
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Clear</a>
                        }
                        <button type="submit" class="btn btn-primary px-4">Search</button>
                    </div>
                </div>
            </form>

            @if (Model.Books == null || !Model.Books.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-journal-x display-4 text-secondary mb-2 d-block"></i>
                    <p class="lead mt-3 mb-0">No books found in the store catalog.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 80px;">Cover</th>
                                <th scope="col">Title</th>
                                <th scope="col">Price</th>
                                <th scope="col">Stock</th>
                                <th scope="col" class="text-end pe-3" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in Model.Books)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                                        {
                                            <img src="~/Images/Books/@book.ImageUrl" alt="@book.Title" style="width: 45px; height: 60px; object-fit: cover; background: #fff; padding: 2px;" class="rounded shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="bg-secondary rounded shadow-sm d-flex align-items-center justify-content-center text-white" style="width: 45px; height: 60px;">
                                                <i class="bi bi-book"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-white">@book.Title</div>
                                        <div class="text-muted small text-truncate" style="max-width: 350px;" title="@book.Description">@book.Description</div>
                                    </td>
                                    <td class="fw-bold text-primary">@book.Price.ToString("0.00") EGP</td>
                                    <td>
                                        @if (book.StockQuantity <= 5)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1 rounded-pill small" style="font-size: 0.75rem;">Low Stock: @book.StockQuantity</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill small" style="font-size: 0.75rem;">In Stock: @book.StockQuantity</span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="d-inline-flex gap-2 justify-content-end align-items-center">
                                            <a asp-controller="Book" asp-action="AddEdit" asp-route-id="@book.BookId" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                Edit
                                            </a>
                                            <form method="post" asp-controller="Book" asp-action="Delete" asp-route-id="@book.BookId" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="m-0" onsubmit="return confirm('Are you sure you want to delete this book?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Paging -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Books pagination" class="mt-4">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchTerm">
                                    <i class="bi bi-chevron-left"></i> Previous
                                </a>
                            </li>

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchTerm">
                                    Next <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
