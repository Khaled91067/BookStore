@using BookStore.ViewModels
@model BookVM
@{
    ViewBag.Title = $"{ViewBag.Operation} Book";
}

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between pb-3 mb-4 border-bottom">
        <h2 class="mb-0 text-white">
            <i class="bi bi-book-half me-2 text-primary"></i>@ViewBag.Operation Book
        </h2>
        <a href="@(string.IsNullOrEmpty(ViewBag.ReturnUrl) ? Url.Action("Index", "Book", new { area = "Admin" }) : ViewBag.ReturnUrl)" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <form asp-action="AddEdit" method="post" enctype="multipart/form-data" class="needs-validation">
        <input type="hidden" asp-for="BookId" />
        <input type="hidden" asp-for="ImageUrl" />
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-header bg-transparent py-3">
                        <h5 class="card-title mb-0 text-secondary small text-uppercase fw-bold">Book Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold text-white"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter book title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <!-- Added Description Section -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-white"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter a compelling summary of the book..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label fw-semibold text-white"></label>
                                <input asp-for="ISBN" class="form-control" placeholder="e.g., 978-3-16-148410-0" />
                                <span asp-validation-for="ISBN" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="StockQuantity" class="form-label fw-semibold text-white">Quantity</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="Price" class="form-label fw-semibold text-white"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
                                    <input asp-for="Price" class="form-control border-start-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedAuthorIds" class="form-label fw-semibold text-white">Assign Authors</label>
                            <select asp-for="SelectedAuthorIds" size="5" class="form-select" asp-items="Model.Authors" multiple>
                            </select>
                            <div class="form-text text-muted small">Hold Ctrl (or Cmd on Mac) to select multiple authors.</div>
                            <span asp-validation-for="SelectedAuthorIds" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-transparent py-3">
                        <h5 class="card-title mb-0 text-secondary small text-uppercase fw-bold">Classification</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label asp-for="PublisherId" class="form-label fw-semibold text-white">Publisher</label>
                            <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.Publishers">
                                <option value="">Select Publisher...</option>
                                @foreach (var pub in Model.Publishers)
                                {
                                    <option value="@pub.PublisherId">@pub.Name</option>
                                }
                            </select>
                            <span asp-validation-for="PublisherId" class="text-danger small"></span>
                        </div>

                        <div class="mb-2">
                            <label class="form-label fw-semibold d-block text-white">Category</label>
                            <div class="p-2 border rounded" style="max-height: 160px; overflow-y: auto; background-color: var(--admin-bg);">
                                @foreach (var cat in Model.Categories)
                                {
                                    <div class="form-check my-1">
                                        <input class="form-check-input" type="radio" asp-for="CategoryId" value="@cat.CategoryId" id="cat_@cat.CategoryId" />
                                        <label class="form-check-label text-truncate w-100 text-white" for="cat_@cat.CategoryId">
                                            @cat.Name
                                        </label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent py-3">
                        <h5 class="card-title mb-0 text-secondary small text-uppercase fw-bold">Media Cover</h5>
                    </div>
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3 position-relative d-inline-block border p-1 bg-white rounded shadow-sm">
                                <img src="~/Images/Books/@Model.ImageUrl" class="rounded img-thumbnail" style="max-height: 140px; object-fit: contain;" alt="Current Book Cover" />
                            </div>
                        }
                        else
                        {
                            <div class="mb-3 border border-dashed rounded py-4 text-muted small" style="background-color: var(--admin-bg);">
                                <i class="bi bi-image d-block fs-3 mb-1 text-secondary"></i> No Image Uploaded
                            </div>
                        }

                        <div class="text-start">
                            <label asp-for="ImageFile" class="form-label fw-semibold small text-white">Upload Cover Photo</label>
                            <input asp-for="ImageFile" type="file" class="form-control form-control-sm" />
                            <span asp-validation-for="ImageFile" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12 text-end">
                <hr class="mb-4" style="opacity: 0.15;" />
                <a href="@(string.IsNullOrEmpty(ViewBag.ReturnUrl) ? Url.Action("Index", "Book", new { area = "Admin" }) : ViewBag.ReturnUrl)" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancel</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">Save Book</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
