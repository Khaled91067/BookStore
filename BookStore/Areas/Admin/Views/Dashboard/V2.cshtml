@model BookStore.ViewModels.AdminDashboardVM
@{
    ViewData["Title"] = "Dashboard Overview";
    Layout = "_AdminLayout";
}

<style>
    .stat-card {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 1rem;
        padding: 1.5rem;
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }
    .stat-icon {
        position: absolute;
        right: -10px;
        bottom: -20px;
        font-size: 6rem;
        opacity: 0.05;
        color: var(--admin-text);
        transition: transform 0.3s ease;
    }
    .stat-card:hover .stat-icon {
        transform: scale(1.1) rotate(-5deg);
    }
    .feature-card {
        background: linear-gradient(145deg, var(--admin-surface) 0%, rgba(30, 41, 59, 0.5) 100%);
        border: 1px solid var(--admin-border);
        border-radius: 1rem;
        padding: 1.5rem;
        text-align: center;
        text-decoration: none;
        color: var(--admin-text);
        transition: all 0.3s ease;
        display: block;
    }
    .feature-card:hover {
        border-color: var(--admin-primary);
        background: rgba(59, 130, 246, 0.05);
        color: var(--admin-text);
    }
    .feature-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
        font-size: 1.25rem;
    }
    .chart-container {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 1rem;
        padding: 1.5rem;
        height: 100%;
    }
</style>

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="fw-bold mb-1">Welcome back, @User.Identity?.Name!</h2>
        <p class="text-muted mb-0">Here's what's happening with your bookstore today.</p>
    </div>
    <div>
        <a asp-action="V1" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Switch to Classic V1</a>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <h6 class="text-muted text-uppercase fw-semibold mb-3" style="letter-spacing: 1px;">Total Revenue</h6>
            <h2 class="fw-bold mb-0 text-success">$@Model.TotalRevenue.ToString("N2")</h2>
            <div class="mt-2 text-success small"><i class="bi bi-shield-check me-1"></i> Completed Payments</div>
            <i class="bi bi-currency-dollar stat-icon"></i>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <h6 class="text-muted text-uppercase fw-semibold mb-3" style="letter-spacing: 1px;">Total Orders</h6>
            <h2 class="fw-bold mb-0 text-primary">@Model.TotalOrders</h2>
            <div class="mt-2 text-primary small"><i class="bi bi-cart-check me-1"></i> Placed in Store</div>
            <i class="bi bi-cart-check stat-icon"></i>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <h6 class="text-muted text-uppercase fw-semibold mb-3" style="letter-spacing: 1px;">Customers</h6>
            <h2 class="fw-bold mb-0 text-warning">@Model.TotalCustomers</h2>
            <div class="mt-2 text-warning small"><i class="bi bi-people me-1"></i> Active Registered Users</div>
            <i class="bi bi-people stat-icon"></i>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <h6 class="text-muted text-uppercase fw-semibold mb-3" style="letter-spacing: 1px;">Total Books</h6>
            <h2 class="fw-bold mb-0 text-info">@Model.TotalBooks</h2>
            <div class="mt-2 text-info small"><i class="bi bi-journal-album me-1"></i> Cataloged Titles</div>
            <i class="bi bi-book stat-icon"></i>
        </div>
    </div>
</div>

<!-- Operations and Analytics Row -->
<div class="row g-4 mb-4">
    <!-- Categories Pie/Doughnut Chart -->
    <div class="col-md-6 col-lg-4">
        <div class="chart-container shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-pie-chart text-info me-2"></i>Categories Breakdown</h5>
            </div>
            <div style="height: 280px; position: relative;">
                <canvas id="categoryDistributionChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Low Stock Warnings -->
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-3 px-3">
                <h5 class="fw-bold mb-0 text-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>Low Stock Warnings</h5>
                <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2 py-1 small" style="font-size: 0.75rem;">Stock &lt;= 5</span>
            </div>
            <div class="card-body px-3 pb-3 pt-2">
                <div class="d-flex flex-column gap-3">
                    @if (Model.LowStockBooks == null || !Model.LowStockBooks.Any())
                    {
                        <div class="text-center text-muted small py-4">
                            <i class="bi bi-check-circle-fill text-success fs-4 d-block mb-1"></i>
                            All inventory items are well-stocked.
                        </div>
                    }
                    else
                    {
                        @foreach (var book in Model.LowStockBooks)
                        {
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                {
                                    <img src="~/Images/Books/@book.ImageUrl" alt="@book.Title" class="rounded shadow-sm" style="width: 32px; height: 42px; object-fit: cover; background: #fff; padding: 2px;" />
                                }
                                else
                                {
                                    <div class="rounded bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 32px; height: 42px;">
                                        <i class="bi bi-book" style="font-size: 0.8rem;"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0" style="overflow: hidden;">
                                    <h6 class="mb-1 fw-semibold text-truncate small text-white" title="@book.Title">@book.Title</h6>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 6px; background-color: rgba(255,255,255,0.05);">
                                            <div class="progress-bar bg-danger" role="progressbar" style="width: @(book.StockQuantity * 20)%" aria-valuenow="@book.StockQuantity" aria-valuemin="0" aria-valuemax="5"></div>
                                        </div>
                                        <span class="small text-danger fw-bold flex-shrink-0" style="font-size: 0.75rem;">@book.StockQuantity Left</span>
                                    </div>
                                </div>
                                <a asp-area="Admin" asp-controller="Book" asp-action="AddEdit" asp-route-id="@book.BookId" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="btn btn-sm btn-outline-light rounded-pill px-3 py-0" style="font-size: 0.75rem;">Restock</a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top Selling Books -->
    <div class="col-md-12 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-3 px-3">
                <h5 class="fw-bold mb-0 text-success"><i class="bi bi-award-fill me-2"></i>Top Selling Books</h5>
            </div>
            <div class="card-body px-3 pb-3 pt-2">
                <div class="d-flex flex-column gap-3">
                    @if (Model.TopSellingBooks == null || !Model.TopSellingBooks.Any())
                    {
                        <div class="text-center text-muted small py-4">No sales transactions found yet.</div>
                    }
                    else
                    {
                        int rank = 1;
                        @foreach (var book in Model.TopSellingBooks)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div class="flex-shrink-0 d-flex align-items-center justify-content-center fw-bold rounded-circle text-white" style="width: 22px; height: 22px; font-size: 0.75rem; background-color: rgba(255,255,255,0.08);">
                                    @rank
                                </div>
                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                {
                                    <img src="~/Images/Books/@book.ImageUrl" alt="@book.Title" class="rounded shadow-sm" style="width: 28px; height: 36px; object-fit: cover; background: #fff; padding: 2px;" />
                                }
                                else
                                {
                                    <div class="rounded bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 28px; height: 36px;">
                                        <i class="bi bi-book" style="font-size: 0.75rem;"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0" style="overflow: hidden;">
                                    <h6 class="mb-0 fw-semibold text-truncate small text-white" title="@book.Title">@book.Title</h6>
                                    <span class="text-muted small" style="font-size: 0.7rem;">@book.TotalSold copies sold</span>
                                </div>
                                <span class="fw-bold text-success flex-shrink-0 small">$@book.TotalRevenue.ToString("N2")</span>
                            </div>
                            rank++;
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders Row -->
<div class="row g-4 mb-5">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-3 px-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-clock-history text-secondary me-2"></i>Recent Orders</h5>
                <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3">Manage Users</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                        <thead>
                            <tr>
                                <th class="ps-3" style="width: 120px;">Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Method</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentOrders == null || !Model.RecentOrders.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted small">No orders found in database.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-primary">#@order.OrderId</td>
                                        <td class="fw-semibold">@order.CustomerName</td>
                                        <td class="small">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                        <td class="fw-bold">$@order.TotalAmount.ToString("N2")</td>
                                        <td>
                                            @if (order.PaymentStatus == "Succeeded")
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill small" style="font-size: 0.75rem;">Succeeded</span>
                                            }
                                            else if (order.PaymentStatus == "Failed")
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1 rounded-pill small" style="font-size: 0.75rem;">Failed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1 rounded-pill small" style="font-size: 0.75rem;">Pending</span>
                                            }
                                        </td>
                                        <td class="small text-muted">@order.PaymentMethod</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="fw-bold mb-4">Quick Management</h4>

<!-- Features Row -->
<div class="row g-4">
    <div class="col-md-6 col-xl-3 d-flex">
        <a asp-controller="Book" asp-action="Index" asp-area="Admin" class="feature-card h-100 w-100">
            <div class="feature-icon-wrapper" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                <i class="bi bi-book"></i>
            </div>
            <h5 class="fw-bold mb-2 text-white">Books Catalog</h5>
            <p class="text-muted small mb-0">Manage catalog and inventory</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-3 d-flex">
        <a asp-controller="Category" asp-action="Index" class="feature-card h-100 w-100">
            <div class="feature-icon-wrapper" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                <i class="bi bi-tags"></i>
            </div>
            <h5 class="fw-bold mb-2 text-white">Categories</h5>
            <p class="text-muted small mb-0">Organize your store genres</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-3 d-flex">
        <a asp-controller="Author" asp-action="Index" class="feature-card h-100 w-100">
            <div class="feature-icon-wrapper" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
                <i class="bi bi-people"></i>
            </div>
            <h5 class="fw-bold mb-2 text-white">Authors</h5>
            <p class="text-muted small mb-0">Manage authors and profiles</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-3 d-flex">
        <a asp-controller="User" asp-action="Index" class="feature-card h-100 w-100">
            <div class="feature-icon-wrapper" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h5 class="fw-bold mb-2 text-white">Users & Roles</h5>
            <p class="text-muted small mb-0">Manage roles and access</p>
        </a>
    </div>
</div>

@section Scripts {
    <!-- Include Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Chart.js global configurations
            Chart.defaults.color = '#94a3b8';
            Chart.defaults.borderColor = 'rgba(51, 65, 85, 0.5)';
            Chart.defaults.font.family = "'Inter', sans-serif";

            // Category Share Doughnut Chart
            const catLabels = @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.CategoryName)));
            const catCounts = @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.BookCount)));

            const ctxCategory = document.getElementById('categoryDistributionChart').getContext('2d');
            new Chart(ctxCategory, {
                type: 'doughnut',
                data: {
                    labels: catLabels,
                    datasets: [{
                        data: catCounts,
                        backgroundColor: [
                            'rgba(59, 130, 246, 0.7)',
                            'rgba(16, 185, 129, 0.7)',
                            'rgba(139, 92, 246, 0.7)',
                            'rgba(245, 158, 11, 0.7)',
                            'rgba(236, 72, 153, 0.7)',
                            'rgba(20, 184, 166, 0.7)',
                            'rgba(99, 102, 241, 0.7)'
                        ],
                        borderColor: '#1e293b',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 10,
                                font: {
                                    size: 9
                                },
                                padding: 8
                            }
                        },
                        tooltip: {
                            padding: 10,
                            backgroundColor: '#1e293b',
                            titleColor: '#f8fafc',
                            bodyColor: '#94a3b8',
                            borderColor: '#334155',
                            borderWidth: 1
                        }
                    },
                    cutout: '65%'
                }
            });
        });
    </script>
}
