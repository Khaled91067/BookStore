@{
    ViewData["Title"] = "Admin Dashboard V1";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>
        <a asp-action="V2" class="btn btn-outline-primary btn-sm"><i class="bi bi-stars me-1"></i>Switch to V2 (New Design)</a>
    </div>

    <div class="row g-4">
        <!-- Manage Books -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center p-4">
                    <i class="bi bi-book text-primary" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3 fw-bold">Manage Books</h5>
                    <p class="card-text text-muted small">Add, edit, or remove books from the store catalog.</p>
                    <a asp-controller="AdminBook" asp-action="Index" class="btn btn-primary mt-2">Go to Books</a>
                </div>
            </div>
        </div>

        <!-- Manage Categories -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center p-4">
                    <i class="bi bi-tags text-success" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3 fw-bold">Manage Categories</h5>
                    <p class="card-text text-muted small">Organize your store by adding or modifying categories.</p>
                    <a asp-controller="Category" asp-action="Index" class="btn btn-success mt-2">Go to Categories</a>
                </div>
            </div>
        </div>

        <!-- Manage Authors -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center p-4">
                    <i class="bi bi-people text-info" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3 fw-bold">Manage Authors</h5>
                    <p class="card-text text-muted small">Maintain the list of authors and their associated images.</p>
                    <a asp-controller="Author" asp-action="Index" class="btn btn-info text-white mt-2">Go to Authors</a>
                </div>
            </div>
        </div>

        <!-- Manage Users -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center p-4">
                    <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3 fw-bold">Manage Users</h5>
                    <p class="card-text text-muted small">View registered users and manage their access roles.</p>
                    <a asp-controller="User" asp-action="Index" class="btn btn-warning text-dark mt-2">Go to Users</a>
                </div>
            </div>
        </div>
    </div>
</div>
