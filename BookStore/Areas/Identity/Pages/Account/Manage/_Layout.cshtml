@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <!-- Header Block -->
            <div class="mb-4">
                <span class="text-info fw-bold text-uppercase tracking-wider small">Account Settings</span>
                <h1 class="h2 fw-bold font-outfit mt-1 mb-1">Manage Your Account</h1>
                <p class="text-muted small">Update your profile info, security settings, and contact details.</p>
            </div>

            <!-- Main Layout Card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
                <div class="row g-0">
                    <!-- Left Sidebar (Nav) -->
                    <div class="col-md-4 col-lg-3 border-end bg-light bg-opacity-50 p-4">
                        <partial name="_ManageNav" />
                    </div>
                    
                    <!-- Right Content Area -->
                    <div class="col-md-8 col-lg-9 p-4 p-sm-5">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
