@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm email";
}



<div class="auth-wrapper py-5 px-3">
    <div class="container d-flex justify-content-center align-items-center">
        <div class="card auth-card border-0 shadow-lg p-4 p-sm-5 rounded-4 bg-white text-center" style="width: 100%; max-width: 500px;">
            @{
                var isError = Model.StatusMessage?.StartsWith("Error") == true;
                if (isError)
                {
                    <div class="icon-circle-danger">
                        <i class="bi bi-shield-x-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold font-outfit text-dark mb-3">Confirmation Failed</h2>
                }
                else
                {
                    <div class="icon-circle-success">
                        <i class="bi bi-patch-check-fill"></i>
                    </div>
                    <h2 class="h3 fw-bold font-outfit text-dark mb-3">Email Confirmed!</h2>
                }
            }

            <div class="mb-4">
                <partial name="_StatusMessage" model="Model.StatusMessage" />
            </div>

            <a asp-page="./Login" class="w-100 btn btn-info text-dark fw-bold py-2.5 rounded-pill shadow-sm mb-2">
                <i class="bi bi-box-arrow-in-right me-1"></i> Log In Now
            </a>
        </div>
    </div>
</div>
