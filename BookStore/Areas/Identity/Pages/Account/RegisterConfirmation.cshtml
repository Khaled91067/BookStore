@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}



<div class="auth-wrapper py-5 px-3">
    <div class="container d-flex justify-content-center align-items-center">
        <div class="card auth-card border-0 shadow-lg p-4 p-sm-5 rounded-4 bg-white text-center" style="width: 100%; max-width: 500px;">
            <div class="icon-circle">
                <i class="bi bi-envelope-check-fill"></i>
            </div>
            
            <h2 class="h3 fw-bold font-outfit text-dark mb-3">Confirm Your Email</h2>
            
            @{
                if (Model.DisplayConfirmAccountLink)
                {
                    <p class="text-secondary small mb-4">
                        This application does not currently have a real email sender registered. In a production environment, a confirmation link would be sent to your email.
                    </p>
                    <div class="alert alert-warning border-0 rounded-3 text-start small mb-4">
                        <i class="bi bi-info-circle-fill me-2 text-warning"></i> Developer Mode: You can confirm your account immediately by clicking the button below.
                    </div>
                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="w-100 btn btn-info text-dark fw-bold py-2.5 rounded-pill shadow-sm mb-3">
                        <i class="bi bi-check2-circle me-1"></i> Confirm Account
                    </a>
                }
                else
                {
                    <p class="text-secondary mb-4">
                        We've sent a confirmation link to your email address. Please check your inbox and click the link to activate your account.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="w-100 btn btn-outline-secondary fw-semibold py-2.5 rounded-pill mb-3">
                        Back to Home
                    </a>
                }
            }
        </div>
    </div>
</div>
