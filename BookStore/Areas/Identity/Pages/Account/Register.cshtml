@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <style>
        .auth-wrapper {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
            position: relative;
            overflow: hidden;
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-wrapper::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 60%);
            pointer-events: none;
            animation: rotateHero 25s linear infinite;
        }

        @@keyframes rotateHero {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .auth-card {
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3) !important;
            z-index: 2;
        }

        .form-floating .form-control {
            border-radius: 0.75rem;
            border: 1px solid rgba(0, 0, 0, 0.12);
            transition: all 0.2s ease;
        }

        .form-floating .form-control:focus {
            border-color: #0dcaf0;
            box-shadow: 0 0 0 3px rgba(13, 202, 240, 0.2);
        }

        .font-outfit {
            font-family: 'Outfit', sans-serif;
        }

        .hover-underline:hover {
            text-decoration: underline !important;
        }
    </style>
}

<div class="auth-wrapper py-5 px-3">
    <div class="container d-flex justify-content-center align-items-center">
        <div class="card auth-card border-0 shadow-lg p-4 p-sm-5 rounded-4 bg-white" style="width: 100%; max-width: 450px;">
            <div class="text-center mb-4">
                <div class="auth-icon mb-2">
                    <i class="bi bi-book-half display-4 text-info"></i>
                </div>
                <h2 class="h3 fw-bold font-outfit text-dark mb-1">Create Account</h2>
                <p class="text-muted small">Join our book community to manage and buy your favorite reads</p>
            </div>
            
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email Address</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                
                <button id="registerSubmit" type="submit" class="w-100 btn btn-info text-dark fw-bold py-2.5 rounded-pill shadow-sm mb-3">
                    <i class="bi bi-person-plus me-2"></i> Register
                </button>
                
                <div class="text-center mt-3">
                    <p class="text-muted small mb-0">
                        Already have an account? 
                        <a asp-page="./Login" class="text-info text-decoration-none fw-semibold hover-underline">Log in</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
