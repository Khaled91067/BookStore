@using BookStore.ViewModels
@model BooksPageVM

@{
    ViewData["Title"] = "Books";
}
@section Styles
{
    <link rel="stylesheet" href="~/css/BooksIndex.css" asp-append-version="true" />
    <style>
        .font-outfit {
            font-family: 'Outfit', sans-serif;
        }

        .hover-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(0, 0, 0, 0.08);
        }

        .hover-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
            border-color: rgba(99, 102, 241, 0.2);
        }

        .text-indigo { color: #4f46e5; }
        .hover-text-info:hover { color: #0dcaf0 !important; }

        .pagination .page-item .page-link {
            border-radius: 0.5rem;
            margin: 0 0.2rem;
            border: none;
            color: #4f46e5;
            font-weight: 500;
        }
        .pagination .page-item.active .page-link {
            background-color: #4f46e5;
            color: white;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
        }
        .pagination .page-item.disabled .page-link {
            color: #6c757d;
            background-color: transparent;
        }

        @@media (max-width: 575.98px) {
            .book-card-cover {
                height: 180px !important;
            }
            .book-card-cover img {
                padding: 0.75rem !important;
            }
            .book-card-body {
                padding: 1rem !important;
            }
            .book-card-title {
                font-size: 0.9rem !important;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            .book-card-description {
                display: none !important;
            }
            .book-card-footer {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 0.5rem;
                margin-top: 0.75rem !important;
            }
            .book-card-price {
                font-size: 1.1rem !important;
            }
            .book-card-btn {
                width: 100%;
                font-size: 0.8rem !important;
                padding: 0.35rem 0.75rem !important;
                text-align: center;
            }
            .book-card-btn-group {
                width: 100%;
                flex-direction: column;
            }
            .book-card-btn-group form {
                width: 100%;
            }
            .book-card-btn-group button {
                width: 100%;
            }
        }
    </style>
}

<div class="container mt-4 mb-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
        <div>
            <span class="text-info fw-bold text-uppercase tracking-wider small">Full Catalog</span>
            <h2 class="h2 fw-bold font-outfit mt-1 mb-3 mb-md-0">@ViewData["Title"]</h2>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-action="AddEdit" asp-area="Admin" asp-controller="AdminBook" class="btn btn-info text-dark fw-bold rounded-pill shadow-sm px-3">
                    <i class="bi bi-plus-lg me-1"></i> Create New Item
                </a>
                <a asp-action="Index" asp-area="Admin" asp-controller="Category" class="btn btn-outline-secondary rounded-pill px-3 fw-semibold">
                    <i class="bi bi-tags me-1"></i> Manage Categories
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        @if (Model.Books != null && Model.Books.Any())
        {
            @foreach (var book in Model.Books)
            {
                <div class="col-6 col-md-4 col-lg-3 d-flex">
                    <div class="card hover-card border-0 bg-white rounded-4 shadow-sm w-100 d-flex flex-column overflow-hidden">
                        
                        <!-- Book Cover Link -->
                        <a asp-controller="UserBook" asp-action="Details" asp-route-id="@book.BookId" class="position-relative d-block bg-light flex-shrink-0 book-card-cover" style="height: 280px;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="~/Images/Books/@book.ImageUrl" class="w-100 h-100 object-fit-contain p-4" alt="@book.Title" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                    <i class="bi bi-book-half display-3 mb-2 text-secondary"></i>
                                    <span class="small">No Cover</span>
                                </div>
                            }
                        </a>

                        <!-- Book Content -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1 book-card-body">
                            <h5 class="card-title fw-bold mb-3 book-card-title">
                                <a asp-controller="UserBook" asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark hover-text-info">
                                    @book.Title
                                </a>
                            </h5>

                            <p class="card-text text-secondary small flex-grow-1 book-card-description" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" title="@book.Description">
                                @book.Description
                            </p>

                            <div class="d-flex align-items-center justify-content-between mt-4 book-card-footer flex-wrap gap-2">
                                <span class="h4 fw-bold text-indigo mb-0 book-card-price">$@book.Price.ToString("F2")</span>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-1 book-card-btn-group ms-auto">
                                        <a asp-controller="AdminBook" asp-area="Admin" asp-action="AddEdit" asp-route-Id="@book.BookId" class="btn btn-outline-secondary btn-sm px-3 rounded-pill book-card-btn">Edit</a>
                                        
                                        <form asp-controller="AdminBook" asp-area="Admin" asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this Book?')" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@book.BookId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-pill book-card-btn">Delete</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    @if (book.StockQuantity > 0)
                                    {
                                        <a asp-controller="Order" asp-action="AddToCart" asp-route-bookId="@book.BookId" class="btn btn-info text-dark fw-bold btn-sm px-4 rounded-pill shadow-sm book-card-btn ms-auto">
                                            <i class="bi bi-cart-plus me-1"></i> Buy
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill small book-card-btn ms-auto">Out of Stock</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-journal-x display-4 text-muted"></i>
                <p class="lead mt-3 text-muted">No books found matching your criteria.</p>
                <a asp-action="Index" class="btn btn-outline-info rounded-pill px-4 mt-2">View All Books</a>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Books pagination" class="mt-5">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchTerm">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchTerm">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>