@using BookStore.ViewModels
@model BooksPageVM

@{
    ViewData["Title"] = "Books";
}
@section Styles
{
    <link rel="stylesheet" href="~/css/BooksIndex.css" asp-append-version="true" />
}

<div class="container mt-4 mb-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
        <h2 class="mb-3 mb-md-0">@ViewData["Title"]</h2>

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-action="AddEdit" asp-area="Admin" asp-controller="AdminBook" class="btn btn-primary">Create New Item</a>
                <a asp-action="Index" asp-area="Admin" asp-controller="Category" class="btn btn-outline-primary">Manage Categories</a>
            </div>
        }
    </div>

    <div class="row g-4">
        @foreach (var book in Model.Books)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="ratio ratio-1x1 bg-light">
                        <img src="~/Images/@book.ImageUrl" class="card-img-top object-fit-contain p-2" alt="@book.Title">
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate" title="@book.Title">@book.Title</h5>
                        <p class="card-text text-muted fw-bold">@book.Price</p>

                        <div class="mt-auto">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2">
                                    <a asp-controller="AdminBook" asp-area="Admin" asp-action="AddEdit" asp-route-Id="@book.BookId" class="btn btn-outline-secondary w-50">Edit</a>

                                    <form asp-controller="AdminBook" asp-area="Admin" asp-action="Delete" method="post" class="w-50">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@book.BookId" />
                                        <button type="submit" class="btn btn-outline-danger w-100">Delete</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                @if (book.StockQuantity > 0)
                                {
                                    <a asp-controller="Order" asp-action="AddToCart" asp-route-bookId="@book.BookId" class="btn btn-success w-100 rounded-pill">Add To Cart</a>
                                }
                                else
                                {
                                    <div class="d-grid">
                                        <span class="badge bg-danger py-2 fs-6">Out Of Stock</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Books pagination" class="mt-5">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchTerm">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchTerm">Next</a>
                </li>

            </ul>
        </nav>
    }
</div>
