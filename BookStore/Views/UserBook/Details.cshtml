@model BookStore.ViewModels.BookDetailsVM

@{
    ViewData["Title"] = Model.Title;
}



<div class="container my-4 my-md-5">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-secondary hover-text-info fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Back to Catalog
        </a>
    </div>

    <div class="card border-0 shadow rounded-4 overflow-hidden bg-white">
        <div class="card-body p-4 p-lg-5">
            <div class="row gx-4 gx-lg-5 align-items-center">

                <!-- Image Section -->
                <div class="col-md-5 col-lg-4 mb-4 mb-md-0 text-center">
                    <div class="book-cover-container p-4 shadow-sm h-100 d-flex align-items-center justify-content-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="~/Images/Books/@Model.ImageUrl"
                                 alt="Cover of @Model.Title"
                                 class="img-fluid rounded-3"
                                 style="max-height: 500px; object-fit: contain;" />
                        }
                        else
                        {
                            <div class="text-muted py-5">
                                <i class="bi bi-book-half display-1 mb-3 text-secondary opacity-50"></i>
                                <p class="mb-0">No Cover Available</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Details Section -->
                <div class="col-md-7 col-lg-8">

                    <div class="d-flex align-items-center mb-3 gap-2 flex-wrap">
                        <span class="badge bg-dark bg-opacity-75 px-3 py-2 rounded-pill text-uppercase tracking-wider fs-7">
                            @(string.IsNullOrEmpty(Model.CategoryName) ? "General" : Model.CategoryName)
                        </span>
                        @if (Model.StockQuantity > 0)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fs-7 border border-success border-opacity-25">
                                <i class="bi bi-check-circle-fill me-1"></i> In Stock (@Model.StockQuantity)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fs-7 border border-danger border-opacity-25">
                                <i class="bi bi-x-circle-fill me-1"></i> Out of Stock
                            </span>
                        }
                    </div>

                    <h1 class="display-5 fw-bold text-dark font-outfit mb-2">@Model.Title</h1>

                    <div class="d-flex flex-wrap align-items-center fs-6 mb-4 text-secondary gap-2 gap-md-4">
                        <div>
                            <i class="bi bi-pen text-info me-1"></i>
                            By <span class="fw-semibold text-dark">
                                @if (Model.Authors != null && Model.Authors.Any())
                                {
                                    for (int i = 0; i < Model.Authors.Count; i++)
                                    {
                                        var author = Model.Authors[i];
                                        <a asp-controller="Author" asp-action="Details" asp-route-id="@author.AuthorId" class="text-indigo hover-text-info text-decoration-none">@author.Name</a>
                                        @if (i < Model.Authors.Count - 1)
                                        {
                                            <span>, </span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span>Unknown Author</span>
                                }
                            </span>
                        </div>
                        <div class="d-none d-md-block text-muted opacity-50">|</div>
                        <div>
                            <i class="bi bi-building text-info me-1"></i>
                            Publisher: <span class="text-dark">@(string.IsNullOrEmpty(Model.PublisherName) ? "Unknown" : Model.PublisherName)</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <span class="display-6 fw-bold text-indigo">@Model.Price.ToString("0.00") EGP</span>
                    </div>

                    <hr class="text-muted opacity-25 my-4" />

                    <div class="mb-5">
                        <h5 class="fw-bold mb-3 text-dark font-outfit">Description</h5>
                        <p class="text-secondary" style="line-height: 1.8; font-size: 1.05rem;">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description available for this book." : Model.Description)
                        </p>
                    </div>

                    <!-- Add to Cart Form -->
                    <form asp-controller="Order" asp-action="AddToCart" asp-route-bookId="@Model.BookId" method="post" class="bg-indigo-soft p-4 rounded-4 border border-primary border-opacity-10">
                        <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-center">
                            @if (Model.StockQuantity > 0)
                            {
                                <div class="d-flex align-items-center me-sm-3">
                                    <label for="quantity" class="fw-bold text-dark me-3 mb-0">Quantity</label>
                                    <div class="input-group shadow-sm" style="width: 140px;">
                                        <button class="btn btn-light border border-secondary border-opacity-25 bg-white" type="button" onclick="document.getElementById('quantity').stepDown()">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number" id="quantity" name="quantity" class="form-control border-secondary border-opacity-25 text-center fw-bold bg-white" value="1" min="1" max="@Model.StockQuantity" />
                                        <button class="btn btn-light border border-secondary border-opacity-25 bg-white" type="button" onclick="document.getElementById('quantity').stepUp()">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-info-custom btn-lg px-5 shadow-sm fw-bold rounded-pill flex-grow-1 flex-sm-grow-0">
                                    <i class="bi bi-cart-plus me-2 fs-5 align-middle"></i> Add to Cart
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-danger mb-0 flex-grow-1 rounded-pill text-center border-0 py-3 fw-semibold">
                                    This book is currently unavailable.
                                </div>
                            }
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>