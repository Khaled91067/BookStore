@using BookStore.ViewModels

@model OrderVM



    <div class="container">

        @if (Model.PaymentStatus == PaymentStatus.Succeeded)
        {
            <div class="card status-card text-center border-0">
                <div class="card-body p-5">
                    <i class="bi bi-check-circle-fill text-success icon-large mb-3 d-block"></i>
                    <h2 class="card-title fw-bold text-success mb-3">Payment Successful</h2>
                    <p class="card-text text-muted fs-5">Thank you for shopping with BookStore. Your order has been confirmed and we will prepare it soon.</p>
                    <hr class="my-4 text-muted">
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Transaction ID: </span>
                        <span class="fw-bold">@Model.TransactionId</span>
                    </div>
                    <a asp-controller="UserBook" asp-action="Index" class="btn btn-success w-100 rounded-pill py-2 fw-bold">Main Home</a>
                </div>
            </div>
        }
        else if (Model.PaymentStatus == PaymentStatus.Pending && Model.PaymentMethod == PaymentMethod.Cash)
        {
            <div class="card status-card text-center border-0">
                <div class="card-body p-5">
                    <i class="bi bi-check-circle-fill text-success icon-large mb-3 d-block"></i>
                    <h2 class="card-title fw-bold text-success mb-3">Order Confirmed</h2>
                    <p class="card-text text-muted fs-5">Thank you! Your order has been placed successfully. You will pay cash on delivery.</p>
                    <hr class="my-4 text-muted">
                    <a asp-controller="UserBook" asp-action="Index" class="btn btn-success w-100 rounded-pill py-2 fw-bold">Continue Shopping</a>
                </div>
            </div>
        }
        else if (Model.PaymentStatus == PaymentStatus.Pending)
        {
            <div class="card status-card text-center border-0">
                <div class="card-body p-5">
                    <i class="bi bi-hourglass-split text-warning icon-large mb-3 d-block"></i>
                    <h2 class="card-title fw-bold text-warning mb-3">Payment Pending</h2>
                    <p class="card-text text-muted fs-5">Your card payment is currently pending or processing. You can check its state in your orders history.</p>
                    <hr class="my-4 text-muted">
                    <a asp-controller="Order" asp-action="ViewOrders" class="btn btn-warning text-dark w-100 rounded-pill py-2 mb-3 fw-bold">View Orders</a>
                    <a asp-controller="UserBook" asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill py-2 fw-bold">Main Home</a>
                </div>
            </div>
        }
        else
        {
            <div class="card status-card text-center border-0">
                <div class="card-body p-5">
                    <i class="bi bi-x-circle-fill text-danger icon-large mb-3 d-block"></i>
                    <h2 class="card-title fw-bold text-danger mb-3">Payment Failed</h2>
                    <p class="card-text text-muted fs-5">Sorry, an error occurred while processing your payment. Please try again or check your card details.</p>
                    <hr class="my-4 text-muted">
                    <a asp-controller="Order" asp-action="Checkout" asp-route-id="@Model.OrderId" class="btn btn-danger w-100 rounded-pill py-2 mb-3 fw-bold">Try Again</a>
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill py-2 fw-bold">Return to Cart</a>
                </div>
            </div>
        }

       
        

    </div>
