@model BookStore.ViewModels.CheckOutVM

@{
    ViewData["Title"] = "Checkout";
    decimal total = Model.OrderItems.Sum(x => x.Price * x.Quantity);
}

@section Styles {
    <style>
        .font-outfit {
            font-family: 'Outfit', sans-serif;
        }
        .text-indigo {
            color: #4f46e5;
        }
        .bg-indigo-soft {
            background-color: rgba(79, 70, 229, 0.04);
        }
        .checkout-card {
            border: 1px solid rgba(0, 0, 0, 0.06);
            border-radius: 1rem;
        }
        .checkout-img-container {
            width: 70px;
            height: 85px;
            flex-shrink: 0;
            background-color: #f8f9fa;
            border-radius: 0.5rem;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .form-control:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.15);
        }
        .form-check-input:checked {
            background-color: #4f46e5;
            border-color: #4f46e5;
        }
        .btn-info-custom {
            background-color: #0dcaf0;
            color: #000;
            transition: all 0.2s ease;
        }
        .btn-info-custom:hover {
            background-color: #0bacce;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(13, 202, 240, 0.3);
        }
    </style>
}

<div class="container my-4 my-md-5">
    <main>
        <form asp-controller="Order" asp-action="Checkout" asp-route-orderId="@Model.OrderId" method="post">
            <div class="row g-4 g-lg-5">
                
                <!-- Order Summary (Right on Desktop, Top on Mobile) -->
                <div class="col-md-5 col-lg-4 order-md-last">
                    <h4 class="d-flex justify-content-between align-items-center mb-3">
                        <span class="font-outfit fw-bold text-dark h5 mb-0">Order Summary</span>
                        <span class="badge bg-dark bg-opacity-75 rounded-pill px-3 py-2 fs-7">@Model.OrderItems.Count Items</span>
                    </h4>

                    <div class="card checkout-card shadow-sm bg-white overflow-hidden mb-4">
                        <div class="card-body p-3">
                            <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                                @foreach (var item in Model.OrderItems)
                                {
                                    <li class="d-flex gap-3 align-items-center pb-3 border-bottom">
                                        <div class="checkout-img-container position-relative">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="~/Images/Books/@item.ImageUrl" class="w-100 h-100 object-fit-contain p-1" alt="@item.ProductName">
                                            }
                                            else
                                            {
                                                <i class="bi bi-book-half text-secondary opacity-50 fs-3"></i>
                                            }
                                            <span class="position-absolute bottom-0 end-0 bg-dark text-white rounded-circle fs-8 fw-bold d-flex align-items-center justify-content-center" style="width: 20px; height: 20px; transform: translate(5px, 5px);">
                                                @item.Quantity
                                            </span>
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <h6 class="mb-1 text-truncate text-dark fw-semibold small" title="@item.ProductName">@item.ProductName</h6>
                                            <p class="mb-0 text-muted small">@item.Price.ToString("0.00") EGP</p>
                                        </div>
                                        <div class="text-end fw-bold text-dark small">
                                            @((item.Price * item.Quantity).ToString("0.00")) EGP
                                        </div>
                                    </li>
                                }
                                
                                <li class="d-flex justify-content-between align-items-center pt-2">
                                    <span class="text-secondary fw-semibold">Total (EGP)</span>
                                    <strong class="text-indigo fs-4 font-outfit">@total.ToString("0.00") EGP</strong>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <button class="w-100 btn btn-info-custom btn-lg fw-bold rounded-pill shadow-sm" type="submit">
                        Complete Order <i class="bi bi-shield-check ms-1"></i>
                    </button>
                </div>

                <!-- Billing Address Form (Left) -->
                <div class="col-md-7 col-lg-8">
                    <div class="card checkout-card shadow-sm bg-white p-4 p-lg-5">
                        <h4 class="mb-4 font-outfit fw-bold text-dark border-bottom pb-3">Billing & Shipping Details</h4>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label asp-for="FirstName" class="form-label fw-semibold text-secondary small">First Name</label>
                                <input asp-for="FirstName" class="form-control rounded-3 py-2" placeholder="e.g. John" required />
                                <span asp-validation-for="FirstName" class="invalid-feedback">Valid first name is required.</span>
                            </div>

                            <div class="col-sm-6">
                                <label asp-for="LastName" class="form-label fw-semibold text-secondary small">Last Name</label>
                                <input asp-for="LastName" class="form-control rounded-3 py-2" placeholder="e.g. Doe" required />
                                <span asp-validation-for="LastName" class="invalid-feedback">Valid last name is required.</span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold text-secondary small">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control rounded-3 py-2" placeholder="you@example.com" required />
                                <span asp-validation-for="Email" class="invalid-feedback">Please enter a valid email address.</span>
                            </div>

                            <div class="col-12">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold text-secondary small">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control rounded-3 py-2" placeholder="+20 1xxxxxxxxx" required />
                                <span asp-validation-for="PhoneNumber" class="invalid-feedback">Please enter a valid phone number.</span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Address" class="form-label fw-semibold text-secondary small">Full Address</label>
                                <input asp-for="Address" class="form-control rounded-3 py-2" placeholder="1234 Main St, Apartment, City" required />
                                <span asp-validation-for="Address" class="invalid-feedback">Please enter your shipping address.</span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25" />

                        <div class="form-check mb-2">
                            <input type="checkbox" class="form-check-input" id="same-address" checked />
                            <label class="form-check-label text-secondary small" for="same-address">Shipping address is the same as my billing address</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="save-info" />
                            <label class="form-check-label text-secondary small" for="save-info">Save this information for next time</label>
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </main>
</div>

