@using BookStore.ViewModels

@model List<OrderVM>
@{
    ViewData["Title"] = "Your Orders";
}
@section Styles
{
    <link rel="stylesheet" href="~/css/ViewOrders.css" asp-append-version="true" />
}

<div class="container mt-4 amazon-orders-view">
    <!-- Top breadcrumbs and title section -->
    <div class="row align-items-center mb-4">
        <div class="col-md-7">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="Identity" asp-page="/Account/Manage/Index" class="text-decoration-none">Your Account</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Your Orders</li>
                </ol>
            </nav>
            <h1 class="h2 fw-bold">Your Orders</h1>
        </div>
        <div class="col-md-5 d-flex align-items-center">
            <form asp-action="ViewOrders" method="get">

                <div class="input-group">
                    <input type="text" name="searchTerm" value="@Context.Request.Query["searchTerm"]" class="form-control" placeholder="Search all orders" aria-label="Search" aria-describedby="button-addon2">
                    <button class="btn btn-dark ms-2 text-white px-3" type="submit" id="button-addon2">Search Orders</button>
                </div>
            </form>

        </div>
    </div>

    <!-- Sub-navigation tabs like in image_0.png -->
   

    @if (!Model.Any())
    {
        <div class="text-center mt-5 py-5 border rounded bg-light shadow-sm">
            <h3>No Orders Found</h3>
            <p class="text-muted">You haven't placed any orders yet.</p>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                @if(order.PaymentStatus==PaymentStatus.Succeeded)
                {

                    <!-- Master card for the whole order -->
                    <div class="order-card shadow-sm">
                        <!-- Order Header (light gray box) - Uses placeholders where data isn't in model -->
                        <div class="card-header">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <div class="row row-cols-auto g-0">
                                        <div class="col">
                                            <div class="order-header-label">Order Placed</div>
                                            <div class="order-header-value">@order.OrderDate</div>
                                        </div>
                                        <div class="col">
                                            <div class="order-header-label">Total</div>
                                            <div class="order-header-value">EGP @order.TotalAmount</div>
                                        </div>
                                        <div class="col">
                                            <div class="order-header-label">Ship To</div>
                                            <div class="order-header-value"><a href="#">@order.CustomerName <i class="bi bi-chevron-down ms-1"></i></a></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 text-md-end text-muted small mt-2 mt-md-0">
                                    <div class="order-header-id">Order # <span>@order.OrderId</span></div>

                                </div>
                            </div>
                        </div>

                        <!-- Inner Card Body containing product list -->
                        <div class="order-item-list">
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="row align-items-center product-row">
                                    <div class="col-md-2 col-3 text-center">
                                        <img src="~/Images/@item.ImageUrl" alt="@item.ProductName" class="book-thumb img-fluid shadow-sm">
                                    </div>
                                    <div class="col-md-7 col-9">
                                        <h5 class="h6 product-title fw-normal mb-1">
                                            <a href="#" class="text-decoration-none">@item.ProductName</a>
                                        </div>
                                        <p class="text-muted small mb-0">Qty: @item.Quantity</p>
                                        <div class="d-flex align-items-center mt-3 gap-2">
                                            <i class="bi bi-repeat fs-5 text-muted"></i>

                                            <a asp-controller="UserBook"
                                           asp-action="Details"
                                           asp-route-Id="@item.ProductId"
                                           class="btn btn-custom-pill">
                                            View your item
                                            </a>

                                            <a asp-controller="Order" asp-action="AddToCart" asp-route-bookId="@item.ProductId" class="btn btn-custom-pill">Buy it again</a>
                                        </div>
                                    </div>

                                
                                }
                            </div>
                        </div>

                    
                }

            }
        </div>
    }
</div>