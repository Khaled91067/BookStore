@using Microsoft.AspNetCore.Identity
@using BookStore.ViewModels
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
        <li class="nav-item">
            @{
                int cartCount = 0;
                if (Context.Session.Get<List<OrderItemVM>>("Cart") != null)
                {

                    var cart = Context.Session.Get<List<OrderItemVM>>("Cart");

                    if(cart != null)
                    {
                        
                    cartCount = cart.Sum(x => x.Quantity);
                    }
                }
            }

            <a class="nav-link position-relative" asp-action="Cart" asp-controller="Order">
                <i class="bi bi-cart2 text-white"></i>
                <span class="position-absolute start-100 translate-middle badge rounded-pill bg-success">
                    @cartCount
                    <span class="visually-hidden">Cart Quantity</span>
                </span>
            </a>
        </li>



    <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a>
    </li>
    <li class="nav-item">
        <form  class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-white">Logout</button>
        </form>

    </li>
}
else
{
    <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
