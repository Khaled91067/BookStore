<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - BookStore</title>
	<script type="importmap"></script>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/BookStore.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	@RenderSection("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
	<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom box-shadow py-2">
        <div class="container-fluid">
            
            <a class="navbar-brand fw-bold fs-4 text-white d-flex align-items-center" asp-area="" asp-controller="UserBook" asp-action="Index">
                <i class="bi bi-book-half text-info me-2"></i> BookStore
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-center">
                
                <ul class="navbar-nav flex-grow-1 mb-2 mb-lg-0 gap-2">
                    <li class="nav-item">
                        <a class="nav-link px-2" asp-area="" asp-controller="UserBook" asp-action="Index">Books</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-2" asp-area="" asp-controller="Order" asp-action="ViewOrders">View Orders</a>
                    </li>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-semibold px-2" asp-area="Admin" asp-controller="User" asp-action="Index">
                                <i class="bi bi-shield-lock-fill me-1"></i> Manage Users
                            </a>
                        </li>
                    }
                </ul>
                
                <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3 mt-3 mt-lg-0">
                    
                    <form asp-controller="UserBook" asp-action="Index" method="get" role="search">
                        <div class="input-group">
                            <input class="form-control border-secondary bg-body text-light"
                                   type="search"
                                   name="search"
                                   placeholder="Search books..."
                                   aria-label="Search" />
                            <button class="btn btn-outline-info" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                    
                </div>
            </div>
        </div>
    </nav>
</header>
	<main role="main" class="pb-3 flex-grow-1">
		<div class="container">
            <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055;">
    
    @if (TempData["Success"] != null)
    {
        <!-- Bootstrap 5 Toast -->
        <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle me-2"></i> <!-- Optional Bootstrap Icon -->
                    @TempData["Success"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

</div>

        @RenderBody()
	    </div>
	</main>

   
	
	<div class="bg-black text-white p-0 ">

    
    
      <footer class="py-5 container">
        <ul class="nav justify-content-center border-bottom pb-3 mb-3">
          <li class="nav-item">
            <a href="#" class="nav-link px-2 text-body-white">Home</a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link px-2 text-body-white">Features</a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link px-2 text-body-white">Pricing</a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link px-2 text-body-white">FAQs</a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link px-2 text-body-white">About</a>
          </li>
        </ul>
        <p class="text-center text-body-white">&copy; 2025 Company, Inc</p>
      </footer>
    </div>


	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
    <script src="../assets/dist/js/bootstrap.bundle.min.js"
            class="astro-vvvwv3sm"></script>
    <script src="checkout.js" class="astro-vvvwv3sm"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
