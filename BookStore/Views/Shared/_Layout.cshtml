<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - BookStore</title>
	<script type="importmap"></script>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/BookStore.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	@RenderSection("Styles", required: false)
	<style>
		.font-outfit {
			font-family: 'Outfit', sans-serif;
		}
		.navbar-custom {
			background-color: #0f172a !important;
		}
		.navbar-custom .nav-link {
			font-family: 'Outfit', sans-serif;
			font-weight: 500;
			color: rgba(255, 255, 255, 0.75) !important;
			transition: color 0.2s ease;
		}
		.navbar-custom .nav-link:hover {
			color: #0dcaf0 !important;
		}
		.navbar-custom .nav-link.active {
			color: #ffffff !important;
			font-weight: 600;
		}
		.footer-gradient {
			background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
			border-top: 1px solid rgba(255, 255, 255, 0.08);
		}
		.hover-text-info {
			transition: color 0.2s ease;
		}
		.hover-text-info:hover {
			color: #0dcaf0 !important;
		}
	</style>
</head>
<body class="d-flex flex-column min-vh-100">
	<header>
		<nav class="navbar navbar-expand-lg navbar-dark navbar-custom border-bottom border-secondary border-opacity-25 py-2">
			<div class="container-fluid">
				
				<a class="navbar-brand fw-bold fs-4 text-white d-flex align-items-center font-outfit" asp-area="" asp-controller="Home" asp-action="Index">
					<i class="bi bi-book-half text-info me-2"></i> BookStore
				</a>
				
				<button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				
				<div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-center">
					
					<ul class="navbar-nav flex-grow-1 mb-2 mb-lg-0 gap-2">
						<li class="nav-item">
							<a class="nav-link px-2" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
						</li>
						<li class="nav-item">
							<a class="nav-link px-2" asp-area="" asp-controller="UserBook" asp-action="Index">Books</a>
						</li>
						@if(!User.IsInRole("Admin"))
						{
							 <li class="nav-item">
								 <a class="nav-link px-2" asp-area="" asp-controller="Order" asp-action="ViewOrders">View Orders</a>
							 </li>
						}
						
						@if (User.IsInRole("Admin"))
						{
							<li class="nav-item">
								<a class="nav-link text-warning fw-semibold px-2" asp-area="Admin" asp-controller="User" asp-action="Index">
									<i class="bi bi-shield-lock-fill me-1"></i> Manage Users
								</a>
							</li>
						}
					</ul>
					
					<div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3 mt-3 mt-lg-0">
						
						<form asp-controller="UserBook" asp-action="Index" method="get" role="search" class="d-flex">
							<div class="input-group input-group-sm rounded-pill overflow-hidden border border-secondary border-opacity-50">
								<input class="form-control bg-white text-white border-0 py-2 ps-3 shadow-none"
									   type="search"
									   name="search"
									   placeholder="Search by Title, Author, or Genre"
									   aria-label="Search"
									   style="min-width: 180px; font-size: 0.85rem;" />
								<button class="btn btn-outline-dark border-0 text-info pe-3" type="submit">
									<i class="bi bi-search"></i>
								</button>
							</div>
						</form>

						<div class="d-flex align-items-center">
							<partial name="_LoginPartial" />
						</div>
						
					</div>
				</div>
			</div>
		</nav>
	</header>

	<main role="main" class="pb-3 flex-grow-1">
		<div class="container-fluid px-0">
			<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055;">
	
				@if (TempData["Success"] != null)
				{
					<!-- Bootstrap 5 Toast -->
					<div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
						<div class="d-flex">
							<div class="toast-body">
								<i class="bi bi-check-circle me-2"></i> <!-- Optional Bootstrap Icon -->
								@TempData["Success"]
							</div>
							<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
						</div>
					</div>
				}

			</div>
			@RenderBody()
		</div>

	</main>

	<div class="footer-gradient text-white py-5">
		<div class="container">
			<div class="row align-items-center justify-content-between g-4">
				<div class="col-md-5 text-center text-md-start">
					<a class="navbar-brand fw-bold fs-4 text-white d-flex align-items-center justify-content-center justify-content-md-start font-outfit" asp-area="" asp-controller="Home" asp-action="Index">
						<i class="bi bi-book-half text-info me-2"></i> BookStore
					</a>
					<p class="text-white-50 small mt-2 mb-0">Discover your next great adventure with our curated selection of masterpieces.</p>
				</div>
				<div class="col-md-5 text-center">
					<ul class="nav justify-content-center justify-content-md-end mb-0 gap-3 font-outfit">
						<li class="nav-item">
							<a asp-controller="Home" asp-action="Index" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">Home</a>
						</li>
						<li class="nav-item">
							<a asp-controller="Info" asp-action="FAQs" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">FAQs</a>
						</li>
						<li class="nav-item">
							<a asp-controller="Info" asp-action="About" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">About</a>
						</li>
					</ul>
				</div>
			</div>
			<hr class="border-white border-opacity-10 my-4" />
			<div class="text-center">
				<p class="text-white-50 small mb-0">&copy; @DateTime.Now.Year Khaled BookStore. All rights reserved.</p>
			</div>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script src="../assets/dist/js/bootstrap.bundle.min.js" class="astro-vvvwv3sm"></script>
	<script src="checkout.js" class="astro-vvvwv3sm"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
