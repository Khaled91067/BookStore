<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - BookStore</title>
	<script type="importmap"></script>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/BookStore.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	@RenderSection("Styles", required: false)
	<style>
		.font-outfit {
			font-family: 'Outfit', sans-serif;
		}
		.navbar-custom {
			background-color: #0f172a !important;
		}
		.navbar-custom .nav-link {
			font-family: 'Outfit', sans-serif;
			font-weight: 500;
			color: rgba(255, 255, 255, 0.75) !important;
			transition: color 0.2s ease;
		}
		.navbar-custom .nav-link:hover {
			color: #0dcaf0 !important;
		}
		.navbar-custom .nav-link.active {
			color: #ffffff !important;
			font-weight: 600;
		}
		.footer-gradient {
			background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
			border-top: 1px solid rgba(255, 255, 255, 0.08);
		}
		.hover-text-info {
			transition: color 0.2s ease;
		}
		.hover-text-info:hover {
			color: #0dcaf0 !important;
		}
		
		/* Premium Header Search Bar styles */
		.search-container-header {
			position: relative;
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}
		.search-input-header {
			background-color: rgba(255, 255, 255, 0.06) !important;
			border: 1px solid rgba(255, 255, 255, 0.12) !important;
			color: #ffffff !important;
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			font-family: 'Outfit', sans-serif;
		}
		.search-input-header::placeholder {
			color: rgba(255, 255, 255, 0.45) !important;
		}
		.search-input-header:focus {
			background-color: rgba(255, 255, 255, 0.12) !important;
			border-color: #0dcaf0 !important;
			box-shadow: 0 0 10px rgba(13, 202, 240, 0.25) !important;
		}
		.search-btn-header {
			color: rgba(255, 255, 255, 0.6) !important;
			transition: color 0.2s ease, transform 0.2s ease;
		}
		.search-btn-header:hover {
			color: #0dcaf0 !important;
			transform: scale(1.05);
		}
		.responsive-nav-text {
			display: inline-block;
			max-width: 200px;
			opacity: 1;
			overflow: hidden;
			white-space: nowrap;
			vertical-align: middle;
			transition: max-width 0.3s ease, opacity 0.3s ease, margin-left 0.3s ease;
			margin-left: 6px;
		}
		@@media (max-width: 1200px) {
			.responsive-nav-text {
				max-width: 0;
				opacity: 0;
				margin-left: 0;
			}
		}
		@@media (max-width: 576px) {
			.navbar-custom .nav-link {
				padding-left: 4px !important;
				padding-right: 4px !important;
				font-size: 0.9rem !important;
			}
			.navbar-brand {
				font-size: 1.1rem !important;
				margin-right: 0 !important;
			}
		}
	</style>
</head>
<body class="d-flex flex-column min-vh-100">
	<header>
		<nav class="navbar navbar-dark navbar-custom border-bottom border-secondary border-opacity-25 py-2">
			<div class="container-fluid d-flex align-items-center justify-content-between flex-nowrap gap-1 gap-sm-2 gap-md-3">
				
				<a class="navbar-brand fw-bold fs-5 text-white d-none d-sm-flex align-items-center font-outfit m-0" asp-area="" asp-controller="Home" asp-action="Index" style="flex-shrink: 0;" title="BookStore">
					<span class="ms-2">BookStore</span>
				</a>
				
				<div class="d-flex align-items-center flex-nowrap">
					<ul class="navbar-nav d-flex flex-row align-items-center gap-1 gap-sm-2 mb-0">
						<li class="nav-item">
							<a class="nav-link px-1 px-sm-2 d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" title="Home">
								<i class="bi bi-house-door"></i>
								<span class="responsive-nav-text">Home</span>
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link px-1 px-sm-2 d-flex align-items-center" asp-area="" asp-controller="UserBook" asp-action="Index" title="Books">
								<i class="bi bi-book"></i>
								<span class="responsive-nav-text">Books</span>
							</a>
						</li>
						@if(!User.IsInRole("Admin"))
						{
							 <li class="nav-item">
								 <a class="nav-link px-1 px-sm-2 d-flex align-items-center" asp-area="" asp-controller="Order" asp-action="ViewOrders" title="View Orders">
									 <i class="bi bi-bag-check"></i>
									 <span class="responsive-nav-text">View Orders</span>
								 </a>
							 </li>
						}
						
						@if (User.IsInRole("Admin"))
						{
							<li class="nav-item">
								<a class="nav-link text-warning fw-semibold px-1 px-sm-2 d-flex align-items-center" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" title="Admin Dashboard">
									<i class="bi bi-speedometer2"></i>
									<span class="responsive-nav-text">Admin Dashboard</span>
								</a>
							</li>
						}
					</ul>
				</div>
				
				<!-- Search Bar: takes the maximum available width, centered, and shrinks with smaller views -->
				<div class="flex-grow-1 mx-1 mx-sm-2 mx-md-4 d-flex justify-content-center" style="max-width: 500px; min-width: 80px;">
					<form asp-controller="UserBook" asp-action="Index" method="get" role="search" class="w-100">
						<div class="input-group input-group-sm rounded-pill overflow-hidden search-container-header">
							<input class="form-control border-0 py-1.5 ps-2 ps-sm-3 shadow-none search-input-header"
								   type="search"
								   name="search"
								   placeholder="Search..."
								   aria-label="Search"
								   style="font-size: 0.8rem;" />
							<button class="btn btn-outline-dark border-0 pe-2 pe-sm-3 search-btn-header bg-transparent" type="submit">
								<i class="bi bi-search" style="font-size: 0.8rem;"></i>
							</button>
						</div>
					</form>
				</div>

				<div class="d-flex align-items-center flex-shrink-0">
					<partial name="_LoginPartial" />
				</div>
			</div>
		</nav>
	</header>

	<main role="main" class="pb-3 flex-grow-1">
		<div class="container-fluid px-0">
			<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055;">
	
				@if (TempData["Success"] != null)
				{
					<!-- Bootstrap 5 Toast -->
					<div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
						<div class="d-flex">
							<div class="toast-body">
								<i class="bi bi-check-circle me-2"></i> <!-- Optional Bootstrap Icon -->
								@TempData["Success"]
							</div>
							<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
						</div>
					</div>
				}
				@if (TempData["Error"] != null)
				{
					<!-- Bootstrap 5 Error Toast -->
					<div class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
						<div class="d-flex">
							<div class="toast-body">
								<i class="bi bi-exclamation-triangle me-2"></i>
								@TempData["Error"]
							</div>
							<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
						</div>
					</div>
				}

			</div>
			@RenderBody()
		</div>

	</main>

	<div class="footer-gradient text-white py-5">
		<div class="container">
			<div class="row align-items-center justify-content-between g-4">
				<div class="col-md-5 text-center text-md-start">
					<a class="navbar-brand fw-bold fs-4 text-white d-flex align-items-center justify-content-center justify-content-md-start font-outfit" asp-area="" asp-controller="Home" asp-action="Index">
						<i class="bi bi-book-half text-info me-2"></i> BookStore
					</a>
					<p class="text-white-50 small mt-2 mb-0">Discover your next great adventure with our curated selection of masterpieces.</p>
				</div>
				<div class="col-md-5 text-center">
					<ul class="nav justify-content-center justify-content-md-end mb-0 gap-3 font-outfit">
						<li class="nav-item">
							<a asp-controller="Home" asp-action="Index" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">Home</a>
						</li>
						<li class="nav-item">
							<a asp-controller="Info" asp-action="FAQs" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">FAQs</a>
						</li>
						<li class="nav-item">
							<a asp-controller="Info" asp-action="About" class="nav-link p-0 text-white-50 text-decoration-none hover-text-info">About</a>
						</li>
					</ul>
				</div>
			</div>
			<hr class="border-white border-opacity-10 my-4" />
			<div class="text-center">
				<p class="text-white-50 small mb-0">&copy; @DateTime.Now.Year Khaled BookStore. All rights reserved.</p>
			</div>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script src="../assets/dist/js/bootstrap.bundle.min.js" class="astro-vvvwv3sm"></script>
	<script src="checkout.js" class="astro-vvvwv3sm"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
