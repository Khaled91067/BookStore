@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <div class="text-center mb-5 py-4 bg-light rounded shadow-sm">
        <h1 class="display-4 fw-bold text-dark mb-2">About Our Bookstore</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            We believe that books have the power to change lives, connect people, and open windows to new worlds.
        </p>
    </div>

    <div class="row g-4 align-items-center mb-5">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3 text-primary">Our Story</h2>
            <p class="text-secondary lh-lg">
                Founded with a passion for literature, our bookstore has grown from a small local shop into a digital haven for book lovers. We curate a vast collection of genres, from timeless classics to modern bestsellers, ensuring every reader finds their perfect match.
            </p>
            <p class="text-secondary lh-lg">
                Our mission is simple: to foster a global community of readers by making knowledge, imagination, and storytelling accessible to everyone, everywhere.
            </p>
        </div>
        <div class="col-md-6 text-center">
            <div class="p-5 bg-primary-subtle rounded-3 text-primary shadow-sm">
                <i class="bi bi-book text-primary" style="font-size: 6rem;"></i>
                <h3 class="mt-3 fw-bold">Where Stories Live</h3>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25" />

    <div class="text-center mb-4">
        <h3 class="fw-bold text-dark">Why Readers Choose Us</h3>
        <p class="text-muted">We combine convenience with a genuine love for books.</p>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <div class="d-inline-flex p-3 bg-success-subtle text-success rounded-circle mb-3">
                        <i class="bi bi-collection-fill fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Vast Collection</h5>
                    <p class="card-text text-muted small">Thousands of titles spanning fiction, non-fiction, academic, and rare editions.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <div class="d-inline-flex p-3 bg-warning-subtle text-warning rounded-circle mb-3">
                        <i class="bi bi-truck fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Fast Delivery</h5>
                    <p class="card-text text-muted small">Carefully packaged and shipped straight to your doorstep in record time.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <div class="d-inline-flex p-3 bg-info-subtle text-info rounded-circle mb-3">
                        <i class="bi bi-chat-heart-fill fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Community First</h5>
                    <p class="card-text text-muted small">We support local authors, organize book clubs, and celebrate reading culture.</p>
                </div>
            </div>
        </div>
    </div>
</div>