@using BookStore.ViewModels
@model HomeVM
@{
    ViewData["Title"] = "Discover Your Next Great Read";
}

<!-- Meta Tags for SEO -->
@section Styles {
    <style>
        /* Modern Premium Animations & Custom Styles for Home Page */
        .hero-section {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
            position: relative;
            overflow: hidden;
            border-radius: 0 0 2rem 2rem;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
            pointer-events: none;
            animation: rotateHero 20s linear infinite;
        }

        @@keyframes rotateHero {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .font-outfit {
            font-family: 'Outfit', sans-serif;
        }

        .hover-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(0, 0, 0, 0.08);
        }

        .hover-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
            border-color: rgba(99, 102, 241, 0.2);
        }

        .category-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            cursor: pointer;
            border: 1px solid rgba(99, 102, 241, 0.1);
        }

        .category-card:hover {
            background: #ffffff;
            transform: scale(1.03);
            border-color: #6366f1;
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.1), 0 4px 6px -2px rgba(99, 102, 241, 0.05) !important;
        }

        .feature-icon {
            font-size: 2rem;
            background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .cta-box {
            background: linear-gradient(135deg, #1e1b4b 0%, #4f46e5 100%);
            border-radius: 1.5rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .cta-box::after {
            content: '';
            position: absolute;
            right: -10%;
            bottom: -10%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .backdrop-blur {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .scrollbar-custom::-webkit-scrollbar {
            height: 6px;
        }
        .scrollbar-custom::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 10px;
        }
        .scrollbar-custom::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.2);
            border-radius: 10px;
        }
        .scrollbar-custom::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.4);
        }

        @@media1 (max-width: 575.98px) {
            .book-card-cover {
                height: 180px !important;
            }
            .book-card-cover img {
                padding: 0.75rem !important;
            }
            .book-card-body {
                padding: 0.75rem !important;
            }
            .book-card-title {
                font-size: 0.9rem !important;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            .book-card-author {
                font-size: 0.75rem !important;
                margin-bottom: 0.5rem !important;
            }
            .book-card-description {
                display: none !important;
            }
            .book-card-footer {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 0.5rem;
                margin-top: 0.75rem !important;
            }
            .book-card-price {
                font-size: 1.1rem !important;
            }
            .book-card-btn {
                width: 100%;
                font-size: 0.8rem !important;
                padding: 0.35rem 0.75rem !important;
                text-align: center;
            }
        }

        .author-card {
            background: #ffffff;
            border: 1px solid rgba(0, 0, 0, 0.06);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .author-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.08) !important;
            border-color: rgba(99, 102, 241, 0.15);
        }
        .author-avatar {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            color: #ffffff;
            font-size: 2rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
            transition: transform 0.3s ease;
        }
        .author-card:hover .author-avatar {
            transform: scale(1.05) rotate(5deg);
        }
    </style>
}

<!-- Hero Section -->
<section class="hero-section text-white py-4 py-md-5 px-3 mb-3 shadow-lg">
    <div class="container-fluid py-3 py-md-5 text-center text-lg-start">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <h1 class="display-4 display-lg-3 fw-bold font-outfit mb-3 lh-sm">
                    Discover Your Next <span class="text-info">Great Adventure</span>
                </h1>
                <p class="lead text-light opacity-90 mb-4 fs-5 fs-md-4 fw-light">
                    Explore thousands of books curated by readers, researchers, and booklovers worldwide. Find bestsellers, classics, and educational masterpieces.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                    <a asp-controller="UserBook" asp-action="Index" class="btn btn-info btn-lg px-4 py-3 fw-bold rounded-pill text-dark shadow-sm">
                        <i class="bi bi-book-half me-2"></i> Browse Books
                    </a>
                    <a href="#featured-books" class="btn btn-outline-light btn-lg px-4 py-3 fw-bold rounded-pill">
                        View Featured
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <!-- Search Box inside Hero -->
                <div class="card bg-dark bg-opacity-50 border-secondary p-4 p-md-5 rounded-4 backdrop-blur shadow">
                    <h3 class="h4 mb-4 text-info fw-semibold">Quick Search Catalog</h3>
                    <form asp-controller="UserBook" asp-action="Index" method="get" id="heroSearchForm">
                        <div class="mb-4">
                            <label for="homeSearchInput" class="form-label text-white small text-uppercase fw-bold">Title, Category or Author</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-transparent border-secondary text-info"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control text-white bg-white-50 border-secondary placeholder-secondary" id="homeSearchInput" name="search" placeholder="Search by Title, Author, Genre" required>
                            </div>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-info btn-lg fw-bold rounded-3" id="homeSearchSubmit">Search Now</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="bg-light py-3">
    <div class="container my-3">
        <div class="text-center mb-4">
            <span class="text-info fw-bold text-uppercase tracking-wider small">Explore Genres</span>
            <h2 class="h1 fw-bold font-outfit mt-1">Browse by Category</h2>
            <p class="text-muted col-md-6 mx-auto">Click any category below to immediately browse all the books inside our bookstore matching the topic.</p>
        </div>

        <div class="d-flex flex-row flex-nowrap overflow-x-auto gap-4 pt-3 pb-3 px-3 scrollbar-custom justify-content-start">
            @if (Model.Categories != null && Model.Categories.Any())
            {
                @foreach (var cat in Model.Categories)
                {
                    var bookCount = cat.Books?.Count ?? 0;
                    <div class="flex-shrink-0" style="width: 220px;">
                        <a asp-controller="UserBook" asp-action="Index" asp-route-search="@cat.Name" class="text-decoration-none">
                            <div class="card category-card p-4 rounded-4 shadow-sm text-center h-100">
                                <div class="mb-3">
                                    <div class="d-inline-flex p-3 bg-info bg-opacity-10 rounded-circle text-info">
                                        @if (cat.Name.Contains("Science") || cat.Name.Contains("Tech") || cat.Name.Contains("Programming"))
                                        {
                                            <i class="bi bi-cpu-fill fs-3"></i>
                                        }
                                        else if (cat.Name.Contains("Fiction") || cat.Name.Contains("Novel"))
                                        {
                                            <i class="bi bi-journal-code fs-3"></i>
                                        }
                                        else if (cat.Name.Contains("Biography") || cat.Name.Contains("History"))
                                        {
                                            <i class="bi bi-mortarboard-fill fs-3"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-bookmark-heart-fill fs-3"></i>
                                        }
                                    </div>
                                </div>
                                <h5 class="fw-bold text-dark mb-1">@cat.Name</h5>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-1 rounded-pill small">
                                    @bookCount Books
                                </span>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="w-100 text-center py-3">
                    <p class="text-muted">No categories loaded.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Featured Books (6 books) -->
<section id="featured-books" class="container my-3 py-3">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-end gap-3 mb-4">
        <div>
            <span class="text-info fw-bold text-uppercase tracking-wider small">Curated Collection</span>
            <h2 class="h1 fw-bold font-outfit mt-1 mb-0">Featured Masterpieces</h2>
        </div>
        <a asp-controller="UserBook" asp-action="Index" class="btn btn-link text-info text-decoration-none fw-semibold p-0">
            View All Books <i class="bi bi-arrow-right-short fs-5 align-middle"></i>
        </a>
    </div>

    <div class="row g-4">
        @if (Model.FeaturedBooks != null && Model.FeaturedBooks.Any())
        {
            @foreach (var book in Model.FeaturedBooks)
            {
                <div class="col-6 col-sm-6 col-md-4 col-lg-3 d-flex">
                    <div class="card hover-card border-0 bg-white rounded-4 shadow-sm w-100 d-flex flex-column overflow-hidden">
                        <!-- Book Cover Link -->
                        <a asp-controller="UserBook" asp-action="Details" asp-route-id="@book.BookId" class="position-relative d-block bg-light flex-shrink-0 book-card-cover" style="height: 280px;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="~/Images/Books/@book.ImageUrl" class="w-100 h-100 object-fit-contain p-4" alt="@book.Title" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                    <i class="bi bi-book-half display-3 mb-2 text-secondary"></i>
                                    <span class="small">No Cover Available</span>
                                </div>
                            }
                            <span class="badge bg-dark bg-opacity-75 position-absolute top-3 end-3 px-3 py-2 rounded-pill fs-7">
                                @(book.Category?.Name ?? "General")
                            </span>
                        </a>

                        <!-- Book Content -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1 book-card-body">
                            <h5 class="card-title fw-bold mb-1 book-card-title">
                                <a asp-controller="UserBook" asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark hover-text-info">
                                    @book.Title
                                </a>
                            </h5>
                            
                            <p class="text-muted small mb-3 book-card-author">
                                By @(book.BookAuthors != null && book.BookAuthors.Any() 
                                     ? string.Join(", ", book.BookAuthors.Select(ba => ba.Author?.Name)) 
                                     : "Unknown Author")
                            </p>

                            <p class="card-text text-secondary small flex-grow-1 book-card-description" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" title="@book.Description">
                                @book.Description
                            </p>

                            <div class="d-flex align-items-center justify-content-between mt-4 book-card-footer">
                                <span class="h4 fw-bold text-indigo mb-0 book-card-price">$@book.Price.ToString("F2")</span>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="AdminBook" asp-area="Admin" asp-action="AddEdit" asp-route-Id="@book.BookId" class="btn btn-outline-secondary btn-sm px-3 rounded-pill book-card-btn">Edit</a>
                                }
                                else
                                {
                                    @if (book.StockQuantity > 0)
                                    {
                                        <a asp-controller="Order" asp-action="AddToCart" asp-route-bookId="@book.BookId" class="btn btn-info text-dark fw-bold btn-sm px-4 rounded-pill shadow-sm book-card-btn">
                                            <i class="bi bi-cart-plus me-1"></i> Buy
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill small book-card-btn">Out of Stock</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-journal-x display-4 text-muted"></i>
                <p class="lead mt-3 text-muted">No books available at the moment. Please check back later!</p>
            </div>
        }
    </div>
</section>

<!-- Top Authors Section -->
<section id="top-authors" class="bg-light py-3">
    <div class="container my-4">
        <div class="text-center mb-2">
            <span class="text-info fw-bold text-uppercase tracking-wider small">Meet the Creators</span>
            <h2 class="h1 fw-bold font-outfit mt-1">Top Featured Authors</h2>
            <p class="text-muted col-md-6 mx-auto">Explore brilliant minds whose books have guided thousands of engineers, business experts, and researchers globally.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Author 1 -->
            <div class="col-6 col-sm-6 col-md-3">
                <div class="card author-card p-4 rounded-4 shadow-sm text-center h-100">
                    <div class="mb-3">
                        <div class="author-avatar font-outfit">RM</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Robert C. Martin</h5>
                    <p class="text-muted small mb-3">Clean Code Guru</p>
                    <div class="mt-auto">
                        <a asp-controller="UserBook" asp-action="Index" asp-route-search="Robert C. Martin" class="btn btn-outline-info btn-sm px-3 rounded-pill fw-semibold">
                            View Books
                        </a>
                    </div>
                </div>
            </div>

            <!-- Author 2 -->
            <div class="col-6 col-sm-6 col-md-3">
                <div class="card author-card p-4 rounded-4 shadow-sm text-center h-100">
                    <div class="mb-3">
                        <div class="author-avatar font-outfit" style="background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%); box-shadow: 0 4px 10px rgba(236, 72, 153, 0.2);">MF</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Martin Fowler</h5>
                    <p class="text-muted small mb-3">Refactoring Pioneer</p>
                    <div class="mt-auto">
                        <a asp-controller="UserBook" asp-action="Index" asp-route-search="Martin Fowler" class="btn btn-outline-info btn-sm px-3 rounded-pill fw-semibold">
                            View Books
                        </a>
                    </div>
                </div>
            </div>

            <!-- Author 3 -->
            <div class="col-6 col-sm-6 col-md-3">
                <div class="card author-card p-4 rounded-4 shadow-sm text-center h-100">
                    <div class="mb-3">
                        <div class="author-avatar font-outfit" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 4px 10px rgba(16, 115, 129, 0.2);">EE</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Eric Evans</h5>
                    <p class="text-muted small mb-3">DDD Pioneer</p>
                    <div class="mt-auto">
                        <a asp-controller="UserBook" asp-action="Index" asp-route-search="Eric Evans" class="btn btn-outline-info btn-sm px-3 rounded-pill fw-semibold">
                            View Books
                        </a>
                    </div>
                </div>
            </div>

            <!-- Author 4 -->
            <div class="col-6 col-sm-6 col-md-3">
                <div class="card author-card p-4 rounded-4 shadow-sm text-center h-100">
                    <div class="mb-3">
                        <div class="author-avatar font-outfit" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); box-shadow: 0 4px 10px rgba(245, 158, 11, 0.2);">SM</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Steve McConnell</h5>
                    <p class="text-muted small mb-3">Code Complete Author</p>
                    <div class="mt-auto">
                        <a asp-controller="UserBook" asp-action="Index" asp-route-search="Steve McConnell" class="btn btn-outline-info btn-sm px-3 rounded-pill fw-semibold">
                            View Books
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="container my-3 py-3">
    <div class="text-center mb-5">
        <span class="text-info fw-bold text-uppercase tracking-wider small">Our Guarantee</span>
        <h2 class="h1 fw-bold font-outfit mt-1">Why BookStore?</h2>
    </div>

    <div class="row g-4 text-center">
        <div class="col-sm-6 col-lg-3">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 transition-all hover-card">
                <div class="mb-3 text-info">
                    <i class="bi bi-truck fs-1"></i>
                </div>
                <h5 class="fw-bold">Free Shipping</h5>
                <p class="text-muted small mb-0">Free delivery on all orders above EGP 500. Shipped straight to your door.</p>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 transition-all hover-card">
                <div class="mb-3 text-info">
                    <i class="bi bi-shield-check fs-1"></i>
                </div>
                <h5 class="fw-bold">Secure Payment</h5>
                <p class="text-muted small mb-0">100% secure payments via credit card, mobile wallet, or online gateways.</p>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 transition-all hover-card">
                <div class="mb-3 text-info">
                    <i class="bi bi-chat-heart fs-1"></i>
                </div>
                <h5 class="fw-bold">24/7 Support</h5>
                <p class="text-muted small mb-0">Our support engineers are available at any time to assist your queries.</p>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 transition-all hover-card">
                <div class="mb-3 text-info">
                    <i class="bi bi-arrow-counterclockwise fs-1"></i>
                </div>
                <h5 class="fw-bold">Easy Returns</h5>
                <p class="text-muted small mb-0">Not satisfied? Return any book in its original condition within 14 days.</p>
            </div>
        </div>
    </div>
</section>
<!-- Call to Action Section -->
@if (User.Identity?.IsAuthenticated == true)
{
    <section class="container my-5 py-3">
        <div class="cta-box p-4 p-md-5 shadow text-center text-md-start">
            <div class="row align-items-center g-4">
                <div class="col-md-8">
                    <h2 class="display-5 fw-bold font-outfit fs-2 fs-md-1">Ready to Find Your Next Book?</h2>
                    <p class="lead text-light opacity-90 mb-0 fs-6 fs-md-5">
                        Discover hundreds of programming, business, and classic books carefully selected for every reader.
                    </p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="d-flex justify-content-center justify-content-md-end">
                        <a asp-controller="UserBook" asp-action="Index" class="btn btn-info text-dark fw-bold px-5 py-3 rounded-pill shadow-sm">
                            Browse All Books
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
else
{
    <section class="container my-5 py-3">
        <div class="cta-box p-4 p-md-5 shadow text-center text-md-start">
            <div class="row align-items-center g-4">
                <div class="col-md-8">
                    <h2 class="display-5 fw-bold font-outfit fs-2 fs-md-1">Join Our Book Community</h2>
                    <p class="lead text-light opacity-90 mb-0 fs-6 fs-md-5">
                        Create an account to save your favorite books and place orders.
                    </p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-md-end">
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-info text-dark fw-bold px-4 py-3 rounded-pill shadow-sm">
                            Create Account
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light fw-bold px-4 py-3 rounded-pill">
                            Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
